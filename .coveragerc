# Coverage.py configuration for RNV Color Palette Manager
# Phase 4 config — adds run_tests.py and root __init__.py to omits.

[run]
branch = True
source = .

# Files/directories that should not be measured for coverage.
# Patterns use forward slashes; coverage.py converts internally for Windows.
omit =
    # Test infrastructure — measuring tests is meaningless
    test_rnv_palette_manager.py
    */test_rnv_palette_manager.py
    run_tests.py
    */run_tests.py
    run_coverage.py
    */run_coverage.py
    tests/*
    tests/**
    */tests/*
    snapshots/*
    snapshots/**
    */snapshots/*
    htmlcov/*

    # Root __init__.py — just imports for package metadata.
    # Subdirectory __init__.py files (core/, ui/, utils/) stay measured.
    # NOTE: this pattern may also match subdirectory __init__.py files via
    # fnmatch behavior. If they disappear from the report, that's expected;
    # they were already at 100% and don't carry information.
    __init__.py
    ./__init__.py

    # Tier 4 — pure dialog/UI surfaces (Phase 3 triage).
    # These had 7-28% coverage because their .exec() calls block under
    # offscreen Qt; the .exec() call inside is the entire surface.
    # Logic that lives inside dialogs gets exercised via TestMainWindowIntegration.
    ui/about_dialog.py
    */ui/about_dialog.py
    ui/batch_export_dialog.py
    */ui/batch_export_dialog.py
    ui/image_upload_dialog.py
    */ui/image_upload_dialog.py
    ui/settings_dialog.py
    */ui/settings_dialog.py
    utils/dialog_helper.py
    */utils/dialog_helper.py

[report]
# Lines/blocks that are intentionally uncovered or trivially uncoverable.
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    raise AssertionError\(.unreachable.\)
    sys\.exit\(app\.exec\(\)\)
    if not .*\.exec\(\):
    if dialog\.exec\(\):

show_missing = True
skip_covered = False

[html]
directory = htmlcov
